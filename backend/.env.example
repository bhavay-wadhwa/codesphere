NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:5173
MONGODB_URL=mongodb://127.0.0.1:27017/codesphere
JWT_SECRET=replace_with_a_long_random_secret

# SMTP provider (for OTPs, forgot-password emails, and contact form messages). Gmail uses smtp.gmail.com, port 587,
# MAIL_SECURE=false, and a Google App Password as MAIL_PASS.
MAIL_HOST=
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=
SENDGRID_API_KEY=
MAIL_FROM=CodeSphere <your-email@example.com>
MAIL_TO=

# Google Cloud OAuth Web Application credentials. Keep the secret on the backend only.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cloudinary (profile-photo uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Use the defaults for local development. The Render deployment uses secure, same-origin cookies.
COOKIE_SAME_SITE=lax
COOKIE_SECURE=false
SERVE_STATIC=false

# Judge0 CE API - for code compilation and execution
# Production: https://ce.judge0.com (public free API, no setup needed)
# Local development (optional): http://localhost:2358 (if running Judge0 locally)
JUDGE0_HOST=https://ce.judge0.com


